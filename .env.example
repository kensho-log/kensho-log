# kensho-log environment variables template.
# Copy to `.env` (gitignored) and fill in values as needed.

# Optional. Stooq CSV API key (required since 2026 to avoid cross-check degradation).
# Obtain at: https://stooq.com/q/d/?s=^spx&get_apikey
# If unset, the S&P 500 price cross-check is skipped and logged as "unavailable".
STOOQ_APIKEY=
